# ============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION - UBUNTU/DEBIAN
# ============================================================================
# Edit this file to select which tools to install
# Set to 'true' to install, 'false' to skip
#
# After editing, run:
#   ./setup-dev-environment.sh --user
#   sudo ./setup-dev-environment.sh --admin
#
# To install ONLY specific tools (ignoring config):
#   ./setup-dev-environment.sh --user --force-install git,curl,docker
#
# Version 1.0.0 - Initial Ubuntu setup script

# ============================================================================
# GENERAL SETTINGS
# ============================================================================
[General]
MinimalInstall=false
UpdatePackages=true    # Run apt update before installation

# ============================================================================
# USER-LEVEL TOOLS (No sudo required where possible)
# ============================================================================

[UserLevel.CoreTools]
git=true
github-cli=true         # gh CLI
curl=true
wget=true
jq=true
yq=true                 # YAML processor
ripgrep=true           # rg - fast grep alternative
fd-find=true           # fd - fast find alternative
fzf=true               # Fuzzy finder
bat=true               # cat with syntax highlighting
tree=true
htop=true
ncdu=true              # Disk usage analyzer
tldr=true              # Simplified man pages

[UserLevel.BuildEssentials]
build-essential=true    # gcc, g++, make
pkg-config=true
autoconf=true
automake=true
libtool=true
cmake=true
ninja-build=true

[UserLevel.Languages.Python]
install=true
pip-packages=true      # pylint, black, flake8, mypy, pytest, ipython

[UserLevel.Languages.NodeJS]
nvm=true                        # Official NVM (installs Node.js LTS automatically)
yarn=true                       # Installed via Corepack or official installer
pnpm=true                       # Installed via official installer
npm-global-packages=true        # typescript, ts-node, eslint, prettier

[UserLevel.Languages.Go]
install=true           # Installed via snap

[UserLevel.Languages.Rust]
install=true           # Installed via rustup

[UserLevel.Languages.Java]
install=true
maven=true
gradle=true

[UserLevel.Languages.Ruby]
install=false
bundler=false

[UserLevel.Languages.PHP]
install=true
composer=true

[UserLevel.Languages.DotNet]
install=false          # .NET SDK

[UserLevel.Databases]
sqlite3=true
postgresql=false       # Requires admin
mysql-client=false     # Client only
mongodb-tools=false    # mongosh, compass
redis-tools=false      # redis-cli

[UserLevel.Containers]
docker-cli=false       # Requires admin for full Docker setup
docker-compose=true    # Standalone binary
kubectl=true
helm=true
k9s=true
kind=true
minikube=false         # Requires admin
argocd-cli=true

[UserLevel.Cloud]
aws-cli=true
azure-cli=true
gcloud=false           # Requires manual setup
terraform=true
packer=true
vault=true
consul=true

[UserLevel.Editors]
vscode=false           # Requires snap or manual install (see AdminLevel)
neovim=true
vim=true
nano=true

[UserLevel.Testing]
httpie=true
curl=true
hey=false              # HTTP load generator

[UserLevel.Security]
nmap=false             # Requires admin
openssl=true
ssh-tools=true         # openssh-client
mkcert=false           # Requires admin

[UserLevel.Documentation]
pandoc=true
hugo=false             # Static site generator
mdbook=false           # Rust documentation tool

[UserLevel.Terminal]
starship=true          # Cross-shell prompt
zoxide=true            # Smart cd
tldr=true              # Simplified man pages
tmux=true
screen=true

[UserLevel.VersionControl]
git-lfs=true
lazygit=false
delta=true             # Better git diff
tig=false              # Text-mode interface for git

[UserLevel.Utilities]
claude-code=true       # Claude Code CLI (requires npm)
rclone=true            # Cloud storage sync
ffmpeg=false           # Requires admin
imagemagick=false      # Requires admin
watchexec=false
direnv=true
just=false             # Command runner

[UserLevel.Fonts]
# Fonts on Linux are typically installed system-wide
nerd-fonts=false       # Will provide manual installation instructions

# ============================================================================
# ADMIN-LEVEL TOOLS (Requires sudo)
# ============================================================================

[AdminLevel.SystemPackages]
git=true               # System git via apt
build-essential=true
software-properties-common=true
apt-transport-https=true
ca-certificates=true
gnupg=true
lsb-release=true

[AdminLevel.Databases]
postgresql=false
mysql-server=false
mongodb=false
redis-server=false

[AdminLevel.Docker]
docker-engine=false    # Full Docker Engine installation
docker-compose=false   # Install via Docker repository

[AdminLevel.SystemTools]
wireshark=false
nmap=false
tcpdump=false

[AdminLevel.Editors]
vscode=false           # Installed via snap or .deb

[AdminLevel.Browsers]
# Ubuntu typically manages browsers through snap or apt
google-chrome=false
firefox=false
chromium=false

[AdminLevel.Multimedia]
ffmpeg=false
imagemagick=false
vlc=false
gimp=false

[AdminLevel.Fonts]
fonts-firacode=false
fonts-cascadia-code=false
fonts-jetbrains-mono=false
