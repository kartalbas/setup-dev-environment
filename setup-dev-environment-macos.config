# ============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION - macOS
# ============================================================================
# Edit this file to select which tools to install
# Set to 'true' to install, 'false' to skip
#
# After editing, run:
#   ./setup-dev-environment-macos.sh --user
#   ./setup-dev-environment-macos.sh --admin
#
# To install ONLY specific tools (ignoring config):
#   ./setup-dev-environment-macos.sh --user --force-install git,curl,docker
#
# Version 1.0.0 - Initial macOS setup script

# ============================================================================
# GENERAL SETTINGS
# ============================================================================
[General]
MinimalInstall=false
InstallHomebrew=true    # Install Homebrew if not present

# ============================================================================
# SYSTEM REQUIREMENTS
# ============================================================================
[SystemRequirements]
xcode-cli-tools=true    # Install Xcode Command Line Tools (required for Homebrew)

# ============================================================================
# USER-LEVEL TOOLS (Installed via Homebrew)
# ============================================================================

[UserLevel.CoreTools]
git=true
gh=true                # GitHub CLI
curl=true
wget=true
jq=true
yq=true                # YAML processor
ripgrep=true          # rg - fast grep alternative
fd=true               # fd - fast find alternative
fzf=true              # Fuzzy finder
bat=true              # cat with syntax highlighting
tree=true
htop=true
ncdu=true             # Disk usage analyzer
tldr=true             # Simplified man pages

[UserLevel.Languages.Python]
install=true          # Python3 via Homebrew
pip-packages=true     # pylint, black, flake8, mypy, pytest, ipython

[UserLevel.Languages.NodeJS]
nvm=true                        # Official NVM (installs Node.js LTS automatically)
yarn=true                       # Installed via Corepack or official installer
pnpm=true                       # Installed via official installer
npm-global-packages=true        # typescript, ts-node, eslint, prettier

[UserLevel.Languages.Go]
install=true          # Installed via Homebrew

[UserLevel.Languages.Rust]
install=true          # Installed via rustup

[UserLevel.Languages.Java]
install=true
maven=true
gradle=true

[UserLevel.Languages.Ruby]
install=false         # macOS comes with Ruby, but can install via Homebrew
bundler=false

[UserLevel.Languages.PHP]
install=false
composer=false

[UserLevel.Languages.DotNet]
install=false         # .NET SDK

[UserLevel.Databases]
sqlite=true
postgresql=false      # PostgreSQL via Homebrew
mysql=false           # MySQL via Homebrew
mongodb-community=false  # MongoDB via Homebrew tap
redis=false           # Redis via Homebrew

[UserLevel.Containers]
docker-desktop=false  # Docker Desktop for Mac (see Applications)
docker-cli=false      # Docker CLI only
docker-compose=true   # Standalone binary
kubectl=true
helm=true
k9s=true
kind=true
minikube=false
argocd-cli=true

[UserLevel.Cloud]
aws-cli=true
azure-cli=true
gcloud=false          # Google Cloud SDK
terraform=true
packer=true
vault=true
consul=true

[UserLevel.Editors]
neovim=true
vim=true
nano=true
# VSCode, IntelliJ, etc. installed via Casks (see Applications section)

[UserLevel.Testing]
httpie=true
hey=false             # HTTP load generator

[UserLevel.Security]
nmap=false
openssl=true
mkcert=true           # Local HTTPS certificates

[UserLevel.Documentation]
pandoc=true
hugo=false            # Static site generator
mdbook=false          # Rust documentation tool

[UserLevel.Terminal]
starship=true         # Cross-shell prompt
zoxide=true           # Smart cd
tldr=true             # Simplified man pages
tmux=true
# iTerm2 installed via Cask (see Applications)

[UserLevel.VersionControl]
git-lfs=true
lazygit=false
delta=true            # Better git diff
tig=false             # Text-mode interface for git

[UserLevel.Utilities]
claude-code=true      # Claude Code CLI (requires npm)
rclone=true           # Cloud storage sync
ffmpeg=true
imagemagick=true
watchexec=false
direnv=true
just=false            # Command runner

[UserLevel.Fonts]
font-fira-code-nerd-font=true
font-cascadia-code=false
font-jetbrains-mono-nerd-font=true
font-hack-nerd-font=false

# ============================================================================
# APPLICATIONS (Homebrew Casks)
# ============================================================================

[Applications.Development]
visual-studio-code=true
iterm2=true                    # Better terminal for macOS
docker=false                   # Docker Desktop
jetbrains-toolbox=false
sublime-text=false
postman=false

[Applications.Browsers]
google-chrome=false
firefox=false
brave-browser=false
arc=false

[Applications.Productivity]
rectangle=true                 # Window management
raycast=false                  # Spotlight replacement
alfred=false                   # Spotlight alternative
notion=false
obsidian=false

[Applications.Communication]
slack=false
discord=false
zoom=false

[Applications.Utilities]
the-unarchiver=true            # Archive utility
appcleaner=true                # Uninstaller
stats=true                     # System monitor in menu bar
keepingyouawake=false          # Prevent sleep

[Applications.Media]
vlc=false
spotify=false
