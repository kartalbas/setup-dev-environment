# ============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================================================
# Edit this file to select which tools to install
# Set to 'true' to install, 'false' to skip
#
# For help, run:
#   Get-Help .\setup-dev-environment-windows.ps1 -Full

# ============================================================================
# GENERAL SETTINGS
# ============================================================================
[General]
InstallPath=D:\bin\scoop
MinimalInstall=false

# ============================================================================
# GIT BOOTSTRAP
# ============================================================================
# Git is installed FIRST, before Scoop and all other tools.
# Right after the installation the settings below are applied.
[General.Git]
# Credential helper for storing passwords / personal access tokens.
#   store   = plaintext file %USERPROFILE%\.git-credentials (asked once, never again)
#   manager = Git Credential Manager (encrypted, Windows Credential Manager)
#   none    = do not touch credential.helper
credential-helper=store

# Ask for name and e-mail (git config --global user.name / user.email)
# if they are not configured yet.
configure-identity=true

# Optional: pre-fill the identity to run fully unattended.
# Leave empty to be prompted interactively.
user-name=
user-email=

# ============================================================================
# USER-LEVEL TOOLS (No admin required)
# ============================================================================

[UserLevel.CoreTools]
git=true
github-cli=true
curl=true
wget=true
jq=true
yq=true
ripgrep=true
fd=true
fzf=true
bat=true
less=true
7zip=true

[UserLevel.UnixTools]
busybox=true
grep=true
sed=true
gawk=true
make=true
which=true
tree-standalone=false
rsync-standalone=false
ssh=false
openssh=true
mc=true

[UserLevel.Languages.Python]
install=true
pip-packages=true

[UserLevel.Languages.NodeJS]
nvm=true
yarn=true
pnpm=true
npm-global-packages=true

[UserLevel.Languages.Go]
install=true

[UserLevel.Languages.Rust]
install=false

[UserLevel.Languages.Java]
install=true
maven=true
gradle=false

[UserLevel.Languages.Ruby]
install=false
bundler=false

[UserLevel.Languages.PHP]
install=false
composer=false

[UserLevel.Languages.DotNet]
install=false

[UserLevel.Languages.Flutter]
install=true
android-sdk=true

[UserLevel.Databases]
sqlite=false
postgresql=true
mongodb=true
redis=true
mysql=true

[UserLevel.Containers]
