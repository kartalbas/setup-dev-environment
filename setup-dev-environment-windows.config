# ============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================================================
# Edit this file to select which tools to install
# Set to 'true' to install, 'false' to skip
#
# After editing, run:
#   .\setup-dev-environment.ps1 -ToolsUserRights
#   .\setup-dev-environment.ps1 -ToolsAdminRights
#
# To install EVERYTHING with admin rights (NOT RECOMMENDED):
#   .\setup-dev-environment.ps1 -ForceAdmin
#
# To install ONLY specific tools (ignoring config):
#   .\setup-dev-environment.ps1 -ToolsUserRights -ForceInstall argocd
#   .\setup-dev-environment.ps1 -ToolsUserRights -ForceInstall argocd,terraform,kubectl
#
# Version 3.1.4 - Fixed ForceInstall to properly handle claude-code installation via npm

# Execution Policy für diese Session ändern
# Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process -Force

# Jetzt das Skript ausführen
# .\setup-dev-environment.ps1 -ToolsUserRights

# ============================================================================
# GENERAL SETTINGS
# ============================================================================
[General]
InstallPath=D:\bin\scoop
MinimalInstall=false

[General.Modules]
path-manager=true           # Load path-manager.ps1 module
winget-manager=true         # Load winget-manager.ps1 module
scoop-manager=true          # Load scoop-manager.ps1 module

# ============================================================================
# USER-LEVEL TOOLS (No admin required)
# ============================================================================

[UserLevel.CoreTools]
git=true                # Installs Git for Windows (includes git-bash for Claude Code)
github-cli=true
curl=true
wget=true
jq=true
yq=true
ripgrep=true
fd=true
fzf=true
bat=true
less=true
7zip=true

[UserLevel.UnixTools]
busybox=true
grep=true
sed=true
gawk=true
make=true
which=true
tree-standalone=false      # Use: busybox tree
rsync-standalone=true     # cwrsync from extras (set false to use busybox rsync)
ssh=false
openssh=true
mc=true

[UserLevel.Languages.Python]
install=true
pip-packages=true

[UserLevel.Languages.NodeJS]
nvm=true                        # Official NVM for Windows (installs Node.js LTS automatically)
yarn=true                       # Installed via Corepack or official installer
pnpm=true                       # Installed via official installer
npm-global-packages=true        # typescript, ts-node, eslint, prettier

[UserLevel.Languages.Go]
install=true

[UserLevel.Languages.Rust]
install=true

[UserLevel.Languages.Java]
install=true
maven=true
gradle=true

[UserLevel.Languages.Ruby]
install=false
bundler=false

[UserLevel.Languages.PHP]
install=true
composer=true

[UserLevel.Languages.DotNet]
install=false

[UserLevel.Languages.Flutter]
install=true
android-sdk=false    # Note: Android SDK requires manual setup via Android Studio

[UserLevel.Databases]
sqlite=true
postgresql=true
mongodb=true
redis=true
mysql=true

[UserLevel.Containers]
docker-cli=true
docker-compose=true
kubectl=true
helm=true
k9s=true
kind=true
minikube=true
argocd-cli=true

[UserLevel.Cloud]
aws-cli=true
azure-cli=true
gcloud=true
terraform=true
packer=true
vault=true
consul=true
ansible=false

[UserLevel.BuildTools]
cmake=true
ninja=true
meson=true
bazel=true
task=true

[UserLevel.Editors]
vscode=true
neovim=true
vim=true
nano=true
sublime-text=true
jetbrains-toolbox=true

[UserLevel.Testing]
postman=true
insomnia=true
httpie=false              # Use: curl or wget
hey=false
k6=false

[UserLevel.Security]
nmap=true
openssl=true
putty=true
winscp=true
mkcert=true

[UserLevel.Documentation]
pandoc=true
hugo=true
mdbook=true
markdownlint-cli=false

[UserLevel.Terminal]
starship=true
zoxide=true
tldr=true

[UserLevel.VersionControl]
git-lfs=true
lazygit=true
delta=true
tig=false

[UserLevel.Utilities]
claude-code=true
github-cli=true
gitlab-cli=true
rclone=true
ffmpeg=true
imagemagick=true
watchexec=true
entr=false
direnv=true
just=true

[UserLevel.Fonts]
firacode-nf=true
cascadiacode-nf=true
jetbrainsmono-nf=true

# ============================================================================
# ADMIN-LEVEL TOOLS (Requires administrator)
# ============================================================================

[AdminLevel.SystemTools]
beyondcompare=true
docker-desktop=true
wireshark=false
powertoys=false
windows-terminal=false
notepadplusplus=false

[AdminLevel.Browsers]
chrome=false
firefox=false
edge-dev=false

[AdminLevel.Other]
# Add other admin tools here if needed
